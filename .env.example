# Host ports used by the isolated Compose project.
PORTFOLIO_API_PORT=58000
PORTFOLIO_POSTGRES_PORT=55432
PORTFOLIO_MINIO_PORT=59000
PORTFOLIO_RABBITMQ_PORT=55672

# Host-side API tooling and integration tests. Keep these URLs aligned with
# any host-port overrides above.
PORTFOLIO_DATABASE_URL=postgresql+psycopg://portfolio:portfolio-local-password@127.0.0.1:55432/portfolio
PORTFOLIO_S3_ENDPOINT_URL=http://127.0.0.1:59000
PORTFOLIO_S3_ACCESS_KEY_ID=portfolio-local-access
PORTFOLIO_S3_SECRET_ACCESS_KEY=portfolio-local-secret
PORTFOLIO_S3_BUCKET=portfolio-documents
PORTFOLIO_S3_REGION=us-east-1
PORTFOLIO_RABBITMQ_URL=amqp://portfolio:portfolio-local-password@127.0.0.1:55672/%2F
PORTFOLIO_API_BASE_URL=http://127.0.0.1:58000
PORTFOLIO_EVENTS_PREFETCH_COUNT=1
PORTFOLIO_EVENTS_REQUEUE_DELAY_SECONDS=0.25
PORTFOLIO_EVENTS_RECONNECT_DELAY_SECONDS=1

# Host-side ML tooling uses a separate settings prefix and deliberately has no
# PostgreSQL setting. Runtime Compose values use service DNS names instead.
PORTFOLIO_ML_S3_ENDPOINT_URL=http://127.0.0.1:59000
PORTFOLIO_ML_S3_ACCESS_KEY_ID=portfolio-local-access
PORTFOLIO_ML_S3_SECRET_ACCESS_KEY=portfolio-local-secret
PORTFOLIO_ML_S3_BUCKET=portfolio-documents
PORTFOLIO_ML_S3_REGION=us-east-1
PORTFOLIO_ML_RABBITMQ_URL=amqp://portfolio:portfolio-local-password@127.0.0.1:55672/%2F
PORTFOLIO_ML_RABBITMQ_TIMEOUT_SECONDS=5
