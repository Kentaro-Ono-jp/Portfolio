{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.reactorfront.dev/contracts/events/common.v1.schema.json",
  "title": "Document processing event common definitions v1",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "objectKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "modelVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "classification": {
      "type": "string",
      "enum": [
        "invoice",
        "report"
      ]
    },
    "failureCode": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "maxLength": 128
    }
  }
}
