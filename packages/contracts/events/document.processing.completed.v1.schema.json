{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.reactorfront.dev/contracts/events/document.processing.completed.v1.schema.json",
  "title": "Document processing completed event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "correlationId",
    "documentId",
    "jobId",
    "objectKey",
    "sourceSha256",
    "modelVersion",
    "classification",
    "confidence"
  ],
  "properties": {
    "eventId": { "$ref": "common.v1.schema.json#/$defs/uuid" },
    "eventType": { "const": "document.processing.completed.v1" },
    "occurredAt": { "$ref": "common.v1.schema.json#/$defs/timestamp" },
    "correlationId": { "$ref": "common.v1.schema.json#/$defs/uuid" },
    "documentId": { "$ref": "common.v1.schema.json#/$defs/uuid" },
    "jobId": { "$ref": "common.v1.schema.json#/$defs/uuid" },
    "objectKey": { "$ref": "common.v1.schema.json#/$defs/objectKey" },
    "sourceSha256": { "$ref": "common.v1.schema.json#/$defs/sha256" },
    "modelVersion": { "$ref": "common.v1.schema.json#/$defs/modelVersion" },
    "classification": { "$ref": "common.v1.schema.json#/$defs/classification" },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
